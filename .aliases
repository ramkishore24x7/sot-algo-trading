# ── Timed WebSocket launchers (waits until 09:15:00 before starting) ─────────────
_LAUNCH_TIME=091500

launch_banknifty_ws() {
  while (( $(date +"%Y%m%d%H%M%S") < $(date +"%Y%m%d")$_LAUNCH_TIME )); do echo -ne "$(date)\r"; done
  echo "$(date) : Launching BankNifty WebSocket..."
  banknifty_ws
}
LAUNCH_BANKNIFTY_WS() { launch_banknifty_ws "$@"; }

launch_nifty_ws() {
  while (( $(date +"%Y%m%d%H%M%S") < $(date +"%Y%m%d")$_LAUNCH_TIME )); do echo -ne "$(date)\r"; done
