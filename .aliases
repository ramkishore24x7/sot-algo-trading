alias FINNIFTY_WS='finnifty_ws'
alias BAJFINANCE_WS='bajfinance_ws'
alias SENSEX_WS='sensex_ws'
alias BANKNIFTY_WS_BG='banknifty_ws_bg'
alias NIFTY_WS_BG='nifty_ws_bg'
alias MIDCPNIFTY_WS_BG='midcpnifty_ws_bg'
alias FINNIFTY_WS_BG='finnifty_ws_bg'
