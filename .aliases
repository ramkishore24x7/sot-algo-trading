# ── Algo Trading ────────────────────────────────────────────────────────────────
ALGO=/Users/ssr/Documents/algo/Fyers
ALGO_VENV=/Users/ssr/Documents/algo/venv
ALGO_PYTHON=$ALGO_VENV/bin/python
ALGO_PIP=$ALGO_VENV/bin/pip

# Anthropic API key — used by LLM signal parser (utils/llm_signal_parser.py)
export ANTHROPIC_API_KEY="<your-anthropic-api-key>"  # set in shell before sourcing

# Activate the algo venv in the current shell
alias algo-activate="source $ALGO_VENV/bin/activate"

# Login
alias ramflogin="$ALGO_PYTHON $ALGO/Login_RAM.py"
alias saiflogin="$ALGO_PYTHON $ALGO/Login_SAI.py"
alias fyers="$ALGO_PYTHON $ALGO/Login_Fyers.py"
alias upstox="$ALGO_PYTHON $ALGO/upstox.py"

# Bots — auto-login if today's config YAML is missing
_algo_config_today() { echo "$ALGO/Trades/$(date +%Y-%m-%d)/config_$(date +%Y-%m-%d).yml"; }
telegram_bot() {
  if [[ ! -f "$(_algo_config_today)" ]]; then
    echo "No config for today — running fyers login first..."
    $ALGO_PYTHON $ALGO/Login_Fyers.py || return 1
  fi
  $ALGO_PYTHON $ALGO/telegram_BOT.py; sleep 5; exit
}
TELEGRAM_BOT() { telegram_bot "$@"; }
alias sot_bot="$ALGO_PYTHON $ALGO/SOT_BOTv8.py"
alias sot_botv7="$ALGO_PYTHON $ALGO/SOT_BOTv7.py"
alias dart="$ALGO_PYTHON $ALGO/dart.py; sleep 5; exit"

# WebSocket servers — foreground (opens in current terminal, blocks)
alias banknifty_ws="$ALGO_PYTHON $ALGO/ws_fyers_BANKNIFTY_v3.py; sleep 5; exit"
alias nifty_ws="$ALGO_PYTHON $ALGO/ws_fyers_NIFTY_v3.py; sleep 5; exit"
alias midcpnifty_ws="$ALGO_PYTHON $ALGO/ws_fyers_MIDCPNIFTY_v3.py; sleep 5; exit"
alias finnifty_ws="$ALGO_PYTHON $ALGO/ws_fyers_FINNIFTY_v3.py; sleep 5; exit"
alias bajfinance_ws="$ALGO_PYTHON $ALGO/ws_fyers_BAJFINANCE_v3.py; sleep 5; exit"
alias sensex_ws="$ALGO_PYTHON $ALGO/ws_fyers_SENSEX_v3.py; sleep 5; exit"
function ws_healthcheck { $ALGO_PYTHON $ALGO/ws_healthcheck.py "$@"; sleep 5; exit; }
function WS_HEALTHCHECK { ws_healthcheck "$@"; }

# WebSocket servers — background (detached, stdout+stderr → Trades/YYYY-MM-DD/<name>.out)
_ws_bg() {
  local script=$1 name=$2
  local logdir="$ALGO/Trades/$(date +%Y-%m-%d)"
  mkdir -p "$logdir"
  nohup $ALGO_PYTHON "$ALGO/$script" >> "$logdir/${name}.out" 2>&1 &
  local pid=$!
  echo $pid > "$logdir/${name}.pid"
  echo "$(date +%H:%M:%S) $name started in background  PID=$pid  log=$logdir/${name}.out"
}
function banknifty_ws_bg  { _ws_bg ws_fyers_BANKNIFTY_v3.py  banknifty_ws;  }
function nifty_ws_bg      { _ws_bg ws_fyers_NIFTY_v3.py      nifty_ws;      }
function midcpnifty_ws_bg { _ws_bg ws_fyers_MIDCPNIFTY_v3.py midcpnifty_ws; }
function finnifty_ws_bg   { _ws_bg ws_fyers_FINNIFTY_v3.py   finnifty_ws;   }
function bajfinance_ws_bg { _ws_bg ws_fyers_BAJFINANCE_v3.py bajfinance_ws; }
function sensex_ws_bg     { _ws_bg ws_fyers_SENSEX_v3.py     sensex_ws;     }

# launch_ws [INSTRUMENT ...] — wait until 09:15, start selected WS in bg, then monitor
# Examples:
#   launch_ws                              → start + monitor all (BANKNIFTY NIFTY SENSEX FINNIFTY MIDCPNIFTY)
#   launch_ws NIFTY BANKNIFTY SENSEX       → start + monitor only those three
launch_ws() {
  local -a instruments
  if [ $# -eq 0 ]; then
    instruments=(BANKNIFTY NIFTY SENSEX FINNIFTY MIDCPNIFTY)
  else
    instruments=("$@")
  fi

  while (( $(date +"%Y%m%d%H%M%S") < $(date +"%Y%m%d")$_LAUNCH_TIME )); do
    echo -ne "$(date)\r"
  done
  echo "\n$(date) : Starting WebSocket servers: ${instruments[*]}"

  for i in "${instruments[@]}"; do
    case $i in
      BANKNIFTY)  banknifty_ws_bg  ;;
      NIFTY)      nifty_ws_bg      ;;
      SENSEX)     sensex_ws_bg     ;;
      FINNIFTY)   finnifty_ws_bg   ;;
      MIDCPNIFTY) midcpnifty_ws_bg ;;
      BAJFINANCE) bajfinance_ws_bg ;;
      *) echo "Unknown instrument: $i (skipped)" ;;
    esac
  done

  ws_healthcheck --watch "${instruments[@]}"
}
function LAUNCH_WS { launch_ws "$@"; }

# Market data / analysis
alias data="$ALGO_PYTHON $ALGO/niftytrader.py"
alias oc="$ALGO_PYTHON $ALGO/optionchain.py"

# Combo: login + telegram bot
alias ssr_start="fyers; upstox; telegram_bot"

