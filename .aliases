alias DATA='data'
alias OC='oc'
alias SSR_START='ssr_start'

# ── LTP quick-check (curl WebSocket servers) ────────────────────────────────────
bn() {
  if [ -z "$1" ]; then
    curl -s "http://localhost:4001/ltp?instrument=NSE:NIFTYBANK-INDEX"
  else
    case $1 in
      NSE:*) curl -s "http://localhost:4001/ltp?instrument=$1" ;;
      *)     curl -s "http://localhost:4001/ltp?instrument=NSE:$1" ;;
    esac
  fi
}
BN() { bn "$@"; }

n50() {
  if [ -z "$1" ]; then
    curl -s "http://localhost:4002/ltp?instrument=NSE:NIFTY50-INDEX"
  else
    case $1 in
      NSE:*) curl -s "http://localhost:4002/ltp?instrument=$1" ;;
      *)     curl -s "http://localhost:4002/ltp?instrument=NSE:$1" ;;
